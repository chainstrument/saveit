# Base de données (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname

# Better Auth
BETTER_AUTH_SECRET=change-me-generate-a-random-secret

# OAuth Google (optionnel v1)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL publique de la webapp (utilisée par l'extension et Better Auth client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (emails transactionnels — reset de mot de passe)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=SaveIt <noreply@yourdomain.com>

# Cloudflare R2 (screenshots des bookmarks)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=saveit-screenshots
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
